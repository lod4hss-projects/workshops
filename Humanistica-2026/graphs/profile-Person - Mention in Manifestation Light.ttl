sdh-shacl:sdh-info_C19_Shape a sh:NodeShape ;
        sh:targetClass sdh-info:C19 ;
        sh:name "Item Collection";
    
        sh:property [
            sh:path sdh-short:P9;
            sh:name "Standard Label";
            sh:datatype xsd:string;
            sh:order 1; 
            sh:minCount 1;
            sh:maxCount 1;
            ];
    
        sh:property [
            sh:path sdh-short:P10;
            sh:name "Alternative Label";
            sh:datatype xsd:string;
            sh:order 2; 
            sh:minCount 1;
            sh:maxCount 1;
            ];
    
        sh:property [
            sh:path sdh-short:P11;
            sh:name "Definition";
            sh:datatype xsd:string;
            sh:order 3; 
            sh:minCount 1;
            ];
    
        sh:property [
            sh:path sdh-short:P12;
            sh:name "Additional Note";
            sh:datatype xsd:string;
            sh:order 4; 
            sh:minCount 1;
            ];
    
        sh:property [
            sh:path crm:P1 ;
            sh:name "is identified by" ;
            sh:class sdh-info:C5 ;
        ];
    
        sh:property [
            sh:path sdh-info:P22 ;
            sh:name "shares the embodiment" ;
            sh:class lrmoo:F2 ;
        ];
    .