  {
    "kind": 1,
    "language": "markdown",
    "value": "PREFIX crm: <http://www.cidoc-crm.org/cidoc-crm/E21>\n\nselect ?s ?p ?o\nwhere {\n  graph <https://github.com/lod4hss-projects/workshops/blob/main/DH25-Lisbon/graphs/sdhss-data.md> \n{?s a crm:E21;\n  ?p ?o}\n}\nlimit 100",
    "metadata": {}
