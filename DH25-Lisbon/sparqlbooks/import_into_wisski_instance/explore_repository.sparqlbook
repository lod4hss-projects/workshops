    "value": "\nINSERT \n  { GRAPH <http://example/bookStore2> { ?book ?p ?v } }\nWHERE\n  { GRAPH  <http://example/bookStore>\n       { ?book dc:date ?date .\n         FILTER ( ?date > \"1970-01-01T00:00:00-02:00\"^^xsd:dateTime )\n         ?book ?p ?v\n  } }\t",
