  {
    "kind": 2,
    "language": "sparql",
    "value": "PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX ps: <http://www.wikidata.org/prop/statement/>\nprefix owl: <http://www.w3.org/2002/07/owl#>\n\nwith <https://github.com/lod4hss-projects/workshops/blob/main/DH25-Lisbon/graphs/sdhss-data.md>\nINSERT {?class a owl:Class}\nWHERE {\nselect distinct ?class\n  where {graph <https://github.com/lod4hss-projects/workshops/blob/main/DH25-Lisbon/graphs/sdhss-data.md> \n  {?s a ?class}\n  }\n}\n",
    "metadata": {}
  },
